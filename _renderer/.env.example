# Required secrets for the renderer. Set in Fly with:
#   fly secrets set RENDERER_TOKEN=… SUPABASE_URL=… SUPABASE_SERVICE_KEY=…

# Shared bearer token. The dashboard's /api/radar/level2 route reads this from
# its own RENDERER_TOKEN env and sends it as `Authorization: Bearer <token>`.
RENDERER_TOKEN=change-me

# Supabase project. Service-role key needed to upload to the radar-tiles bucket
# without RLS getting in the way.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# Optional. Defaults to radar-tiles (matches existing dashboard expectation).
# RENDERER_STORAGE_BUCKET=radar-tiles
