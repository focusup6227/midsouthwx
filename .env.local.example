# Copy this to .env.local and fill in real values. .env.local is gitignored.

# Supabase (from Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
# Prefer publishable key (new dashboard); JWT anon key still works as fallback.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LEGACY_ANON_JWT_IF_NEEDED

# Server-only (never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Production: canonical public origin for invite/magic-link redirects (optional locally when Host is forwarded correctly).
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Telegram bot username (no @ prefix). Set after creating bot in @BotFather.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=midsouthwxbot

# Mapbox (radar map basemap + labels). Free tier at account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# On-demand NEXRAD Level II renderer (Fly.io). Server-only token; never NEXT_PUBLIC_.
RENDERER_BASE_URL=https://midsouthwx-radar.fly.dev
RENDERER_TOKEN=your-64-char-hex-secret

# NWS API User-Agent — required by api.weather.gov. Include a contact so they
# can reach you if your poller misbehaves. Used by nws-poll Edge Function and
# the subscriber invite ZIP→county lookup.
NWS_USER_AGENT=midsouthwx (you@example.com)

# Optional: Resend.com API key for transactional email (operator-initiated
# subscriber invites). Free tier = 100 emails/day. Leave unset and the invite
# UI falls back to copy-paste the activation link.
RESEND_API_KEY=
EMAIL_FROM=Mid-South WX <onboarding@resend.dev>
